diff --git a/src/xenia/base/main_android.cc b/src/xenia/base/main_android.cc
index 5e43dbc..fbe4b97 100644
--- a/src/xenia/base/main_android.cc
+++ b/src/xenia/base/main_android.cc
@@ -164,6 +164,36 @@ JNIEnv* GetAndroidThreadJniEnv() {
   return static_cast<JNIEnv*>(pthread_getspecific(android_thread_jni_env_key_));
 }

+JavaVM* GetAndroidJavaVM() { return android_java_vm_; }
+
 jobject GetAndroidApplicationContext() { return android_application_context_; }

+static jobject android_activity_ = nullptr;
+static jmethodID android_activity_handle_fatal_error_ = nullptr;
+
+void SetAndroidActivity(JNIEnv* env, jobject activity) {
+  if (android_activity_ && env) {
+    env->DeleteGlobalRef(android_activity_);
+    android_activity_ = nullptr;
+  }
+  android_activity_handle_fatal_error_ = nullptr;
+  if (activity && env) {
+    android_activity_ = env->NewGlobalRef(activity);
+    jclass activity_class = env->GetObjectClass(android_activity_);
+    if (activity_class) {
+      android_activity_handle_fatal_error_ = env->GetMethodID(
+          activity_class, "handleFatalError", "(Ljava/lang/String;)V");
+      env->DeleteLocalRef(activity_class);
+    }
+  }
+}
+
+jobject GetAndroidActivity() {
+  return android_activity_;
+}
+
+jmethodID GetAndroidActivityHandleFatalErrorMethodID() {
+  return android_activity_handle_fatal_error_;
+}
+
 }  // namespace xe
