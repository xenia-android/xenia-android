<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.XeniaAndroid" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/xenia_green</item>
        <item name="colorPrimaryVariant">@color/xenia_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/xenia_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/xenia_green_dark</item>
    </style>

    <!-- Full-screen theme used by EmulatorActivity and GpuTraceViewerActivity -->
    <style name="Theme.XeniaAndroid.Fullscreen"
        parent="Theme.XeniaAndroid">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowKeepScreenOn">true</item>
    </style>
</resources>
